# NemoClaw STR Agent -- environment variable template.
# Copy to .env and fill in real values. Never commit .env.

# --- Stripe (TEST mode only; sk_live_ keys are refused) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Nous Research Hermes (formatting / classification / templates) ---
NOUS_PORTAL_API_KEY=sk-nous-...
NOUS_PORTAL_BASE_URL=https://inference-api.nousresearch.com/v1
HERMES_MODEL=nous-hermes-2-pro-llama-3-8b

# --- NVIDIA NIM / Nemotron Ultra (anomaly / pricing / AEO reasoning) ---
NVIDIA_NIM_API_KEY=nvapi-...
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=nvidia/nemotron-ultra-253b-v1

# --- Metronome (usage-based billing, optional) ---
METRONOME_API_KEY=

# --- Carryall / Ed25519 envelope signing ---
# Generate: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# If unset, an ephemeral key is generated per session (demo only).
CARRYALL_SIGNING_KEY_B64=

# --- Audit log ---
AUDIT_LOG_PATH=.demo_state/audit.jsonl

# --- Demo mode (default true -- mocks Stripe writes, no real charges) ---
DEMO_MODE=true

# --- Spend approval gate ---
REQUIRE_APPROVAL_THRESHOLD_CENTS=50000

# --- ConductorOne control plane ---
C1_API_KEY=
C1_API_SECRET=
C1_BASE_URL=
C1_VENDOR_APP_ID=
C1_VENDOR_ENTITLEMENT_ID=

# --- App ---
APP_PORT=8000
REDIS_URL=redis://redis:6379/0
