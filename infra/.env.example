# NemoClaw SMB Ops Agent — environment template
# Copy to ../.env (repo root) and fill. .env is gitignored.

# --- Hermes Agent (Nous Research) ---
# Nous Portal key OR OpenRouter/NVIDIA NIM endpoint. Hermes is the primary orchestrator.
NOUS_PORTAL_API_KEY=
HERMES_MODEL=hermes-agent

# --- NVIDIA (NemoClaw sandbox + Nemotron 3 Ultra reasoning) ---
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=nvidia/nemotron-3-ultra
# NemoClaw / OpenShell sandbox toggle (true = run skills inside the sandbox)
NEMOCLAW_SANDBOX=true

# --- Stripe Skills for Hermes (TEST MODE ONLY) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Intuit QuickBooks (sandbox) — mocked for demo ---
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_SANDBOX=true

# --- GBrain (Garry Tan's memory MCP; PGLite) ---
GBRAIN_MCP_URL=
# When unset, the local GBrain-contract mock is used.

# --- ConductorOne control plane (OPTIONAL — gated on C1 blessing) ---
# Leave unset to use the local-config policy mock (control_plane/policy_mock.yaml).
C1_API_KEY=
C1_BASE_URL=

# --- Approval gate ---
SPEND_APPROVAL_THRESHOLD=100   # REQUIRE_APPROVAL fires above this (USD)

# --- App ---
APP_PORT=8000
REDIS_URL=redis://redis:6379/0
