# Secrets — never commit
.env
*.key
*.pem
secrets/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node / UI
node_modules/
ui/dist/
ui/build/
*.local

# Data / runtime
*.db
*.sqlite
audit/*.jsonl
gbrain/data/
docker/state/
.demo_state/
logs/
.nemoclaw/

# OS / editor
.DS_Store
.idea/
.vscode/

# Tenant runtime data — real/sensitive tenants live under $NEMOCLAW_TENANTS_ROOT
# outside this public repo. Only the synthetic _sample_str sample is tracked.
# The sample's small transactions.csv IS tracked so `make tenant-run TENANT=_sample_str` works.
tenants/*/brain/
tenants/*/audit/
tenants/*/.env
# Exclude real data dirs while keeping the synthetic sample's data/ tracked.
# Real tenants' data/ will also be excluded by $NEMOCLAW_TENANTS_ROOT placement.
tenants/[!_]*/data/

# generated tenant analysis reports and loop runtime state
tenants/*/data/report.md
tenants/*/data/state/
tenants/*/data/escalations.jsonl
